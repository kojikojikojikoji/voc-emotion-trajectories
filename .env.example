# Copy to .env and adjust if needed. Everything works without a .env file.

# Directory for datasets. Relative paths are resolved from the repository
# root, so the default works from any working directory. The raw DailyDialog
# archive is expected at $VOC_DATA_DIR/raw/ijcnlp_dailydialog.zip, the raw
# Persuasion for Good files under $VOC_DATA_DIR/raw/persuasionforgood/, and
# the committed samples live under $VOC_DATA_DIR/sample/.
VOC_DATA_DIR=./data
